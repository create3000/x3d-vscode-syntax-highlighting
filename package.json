{
  "name": "x3d-vscode-syntax-highlighting",
  "publisher": "create3000",
  "displayName": "X3D Syntax Highlighting for VS Code",
  "description": "Provides Syntax Highlighting for All X3D Encodings and VRML 2.0 files in VS Code",
  "version": "1.0.6",
  "license": "MIT",
  "icon": "images/icon.png",
  "homepage": "https://github.com/create3000/x3d-vscode-syntax-highlighting",
  "author": {
    "name": "Holger Seelig",
    "email": "holger.seelig@gmail.com",
    "url": "https://github.com/create3000"
  },
  "contributors": [
    {
      "name": "Holger Seelig",
      "email": "holger.seelig@gmail.com",
      "url": "https://github.com/create3000"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/create3000/x3d-vscode-syntax-highlighting.git"
  },
  "bugs": {
    "url": "https://github.com/create3000/x3d-vscode-syntax-highlighting/issues"
  },
  "keywords": [
    "3D",
    "JSON",
    "syntax highlighting",
    "tools",
    "VRML",
    "WRL",
    "X3D",
    "X3DJ",
    "X3DV"
  ],
  "galleryBanner": {
    "color": "#383838",
    "theme": "dark"
  },
  "sponsor": {
    "url": "https://www.patreon.com/X_ITE"
  },
  "scripts": {
    "release": "node build/release.js",
    "snippets": "node build/snippets.js"
  },
  "devDependencies": {
    "shell-tools": "^1.1.9",
    "x_ite-node": "^2.0.10"
  },
  "extensionPack": [
    "create3000.x-ite-vscode",
    "create3000.x-ite-vscode-formatter"
  ],
  "engines": {
    "vscode": "^1.14.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "contributes": {
    "languages": [
      {
        "id": "X3D",
        "aliases": [
          "X3D",
          "VRML"
        ],
        "extensions": [
          ".x3dv",
          ".wrl"
        ],
        "configuration": "./X3D.language-configuration.json"
      },
      {
        "id": "xml",
        "extensions": [
          ".x3d"
        ]
      },
      {
        "id": "json",
        "extensions": [
          ".x3dj"
        ]
      }
    ],
    "snippets": [
      {
        "language": "X3D",
        "path": "./snippets/X3D.json"
      }
    ],
    "grammars": [
      {
        "language": "X3D",
        "scopeName": "source.x3d",
        "path": "./syntaxes/X3D.tmLanguage.json"
      }
    ]
  }
}
