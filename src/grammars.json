{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "strong",
          "match": "^#(?:X3D|VRML) V[\\d\\.]+ utf8\\s+.*?$"
        },
        {
          "name": "comment.line",
          "match": "#.+$"
        },
        {
          "name": "keyword.control",
          "match": "\\b(PROFILE|COMPONENT|UNIT|META|EXTERNPROTO|PROTO|IS|DEF|USE|ROUTE|TO|IMPORT|EXPORT|DESCRIPTION)\\b"
        },
        {
          "name": "variable.parameter",
          "match": "\\b(Core|Interchange|Interactive|Immersive|Full|MPEG-4)\\b"
        },
        {
          "name": "variable.parameter",
          "match": "\\b(CADGeometry|Core|CubeMapTexturing|DIS|EnvironmentalEffects|EnvironmentalSensor|EventUtilities|Followers|Geometry2D|Geometry3D|Geospatial|Grouping|HAnim|Interpolation|KeyDeviceSensor|Layering|Layout|Lighting|Navigation|Networking|NURBS|ParticleSystems|Picking|PointingDeviceSensor|Shaders|TextureProjection|Rendering|RigidBodyPhysics|Scripting|Shape|Sound|Text|Texturing|Texturing3D|Time|VolumeRendering|X_ITE)\\b"
        },
        {
          "name": "constant.character",
          "match": "\\b(TRUE|FALSE|NULL)\\b"
        },
        {
          "name": "variable.language",
          "match": "\\b(initializeOnly|inputOutput|inputOnly|outputOnly|field|eventIn|eventOut|exposedField)\\b"
        },
        {
          "name": "variable.language",
          "match": "\\b(SFBool|MFBool|SFColor|MFColor|SFColorRGBA|MFColorRGBA|SFDouble|MFDouble|SFFloat|MFFloat|SFImage|MFImage|SFInt32|MFInt32|SFMatrix3d|MFMatrix3d|SFMatrix3f|MFMatrix3f|SFMatrix4d|MFMatrix4d|SFMatrix4f|MFMatrix4f|SFNode|MFNode|SFRotation|MFRotation|SFString|MFString|SFTime|MFTime|SFVec2d|MFVec2d|SFVec2f|MFVec2f|SFVec3d|MFVec3d|SFVec3f|MFVec3f|SFVec4f|MFVec4f)\\b"
        },
        {
          "match": "\\b([^\\x30-\\x39\\x00-\\x20\\x22\\x23\\x27\\x2b\\x2c\\x2d\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]{1}[^\\x00-\\x20\\x22\\x23\\x27\\x2c\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]*)\\s*{",
          "captures": {
            "1": { "name": "support.class" }
          }
        },
        {
          "name": "constant.numeric",
          "match": "\\b(?:0[xX][\\da-fA-F]+|[+-]?(?:(?:(?:\\d*\\.\\d+)|(?:\\d+(?:\\.)?))(?:[eE][+-]?\\d+)?))\\b"
        },
        {
          "name": "variable.parameter",
          "match": "^(\\s*)"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.X3D",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.X3D",
          "match": "\\\\."
        }
      ]
    }
  },
  "scopeName": "source.x3d"
}
