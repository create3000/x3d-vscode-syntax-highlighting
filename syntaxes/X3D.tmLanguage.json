{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "X3D",
  "patterns": [
    {
      "include": "#blockComment"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "comment": "headers",
          "name": "constant.language.x3d",
          "match": "^#(?:X3D|VRML) V\\d+\\.\\d+ utf8\\s+.*?$"
        },
        {
          "comment": "single-line comments",
          "name": "comment.line.x3d",
          "match": "#.+$"
        },
        {
          "comment": "DEF statements",
          "match": "\\b(DEF)\\s+([^\\x30-\\x39\\x00-\\x20\\x22\\x23\\x27\\x2b\\x2c\\x2d\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]{1}[^\\x00-\\x20\\x22\\x23\\x27\\x2c\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.x3d" },
            "2": { "name": "variable.other.readwrite.x3d" }
          }
        },
        {
          "comment": "UNIT statements",
          "match": "\\b(UNIT)\\s+(angle|force|length|mass)\\b",
          "captures": {
            "1": { "name": "keyword.control.x3d" },
            "2": { "name": "constant.language.x3d" }
          }
        },
        {
          "comment": "keywords",
          "name": "keyword.control.x3d",
          "match": "\\b(PROFILE|COMPONENT|UNIT|META|EXTERNPROTO|PROTO|IS|DEF|USE|ROUTE|TO|IMPORT|EXPORT|AS|DESCRIPTION)\\b"
        },
        {
          "comment": "constants",
          "name": "constant.language.x3d",
          "match": "\\b(TRUE|FALSE|NULL)\\b"
        },
        {
          "comment": "access types and field types",
          "match": "\\b(initializeOnly|inputOutput|inputOnly|outputOnly|field|eventIn|eventOut|exposedField)\\s+([SM]F(?:Bool|Color(?:RGBA)?|Double|Float|Image|Int32|Matrix[34][df]|Node|Rotation|String|Time|Vec[234][df]))\\b",
          "captures": {
            "1": { "name": "keyword.control.x3d" },
            "2": { "name": "constant.language.x3d" }
          }
        },
        {
          "comment": "node type names",
          "match": "\\b([^\\x30-\\x39\\x00-\\x20\\x22\\x23\\x27\\x2b\\x2c\\x2d\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]{1}[^\\x00-\\x20\\x22\\x23\\x27\\x2c\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]*)\\s*{",
          "captures": {
            "1": { "name": "support.class.x3d" }
          }
        },
        {
          "comment": "profile names",
          "name": "variable.other.readwrite.x3d",
          "match": "\\b(CADInterchange|Core|Full|Immersive|Interactive|Interchange|MedicalInterchange|MPEG4Interactive)\\b"
        },
        {
          "comment": "component names",
          "name": "variable.other.readwrite.x3d",
          "match": "\\b(CADGeometry|Core|CubeMapTexturing|DIS|EnvironmentalEffects|EnvironmentalSensor|EventUtilities|Followers|Geometry2D|Geometry3D|Geospatial|Grouping|HAnim|Interpolation|KeyDeviceSensor|Layering|Layout|Lighting|NURBS|Navigation|Networking|ParticleSystems|Picking|PointingDeviceSensor|Rendering|RigidBodyPhysics|Scripting|Shaders|Shape|Sound|Text|TextureProjection|Texturing|Texturing3D|Time|VolumeRendering|X_ITE)\\b"
        },
        {
          "comment": "hex and floating-point numbers",
          "name": "constant.numeric.x3d",
          "match": "\\b(?:0[xX][\\da-fA-F]+|[+-]?(?:(?:(?:\\d*\\.\\d+)|(?:\\d+(?:\\.)?))(?:[eE][+-]?\\d+)?))\\b"
        },
        {
          "name": "punctuation.separator.x3d",
          "match": "[:\\.,]"
        },
        {
          "comment": "rest of uncolored words (field and node names)",
          "name": "variable.other.readwrite.x3d",
          "match": "([^\\x30-\\x39\\x00-\\x20\\x22\\x23\\x27\\x2b\\x2c\\x2d\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]{1}[^\\x00-\\x20\\x22\\x23\\x27\\x2c\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]*)"
        }
      ]
    },
    "blockComment": {
      "name": "comment.block.x3d",
      "begin": "#\\/\\*",
      "end": "\\*\\/#",
      "beginCaptures": {
        "0": {
          "name": "comment.block.begin.x3d"
        }
      },
      "endCaptures": {
        "0": {
          "name": "comment.block.end.x3d"
        }
      }
    },
    "strings": {
      "name": "string.quoted.double.x3d",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.language.escape.x3d",
          "match": "\\\\."
        }
      ]
    }
  },
  "scopeName": "source.x3d"
}
