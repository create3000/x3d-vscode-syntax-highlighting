{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "X3D",
  "patterns": [
    {
      "include": "#blockComment"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "strong",
          "match": "^#(?:X3D|VRML) V\\d+\\.\\d+ utf8\\s+.*?$"
        },
        {
          "name": "comment.line",
          "match": "#.+$"
        },
        {
          "match": "\\b(DEF)\\s+(\\w+)\\b",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "variable.parameter" }
          }
        },
        {
          "match": "\\b(UNIT)\\s+(angle|force|length|mass)\\b",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "constant.character" }
          }
        },
        {
          "name": "keyword.control",
          "match": "\\b(PROFILE|COMPONENT|UNIT|META|EXTERNPROTO|PROTO|IS|DEF|USE|ROUTE|TO|IMPORT|EXPORT|AS|DESCRIPTION)\\b"
        },
        {
          "name": "constant.character",
          "match": "\\b(TRUE|FALSE|NULL)\\b"
        },
        {
          "match": "\\b(initializeOnly|inputOutput|inputOnly|outputOnly|field|eventIn|eventOut|exposedField)\\s+([SM]F(?:Bool|Color(?:RGBA)?|Double|Float|Image|Int32|Matrix[34][df]|Node|Rotation|String|Time|Vec[234][df]))\\b",
          "captures": {
            "1": { "name": "keyword.control" },
            "2": { "name": "variable.language" }
          }
        },
        {
          "match": "\\b([^\\x30-\\x39\\x00-\\x20\\x22\\x23\\x27\\x2b\\x2c\\x2d\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]{1}[^\\x00-\\x20\\x22\\x23\\x27\\x2c\\x2e\\x5b\\x5c\\x5d\\x7b\\x7d\\x7f]*)\\s*{",
          "captures": {
            "1": { "name": "support.class" }
          }
        },
        {
          "name": "variable.parameter",
          "match": "\\b(Core|Interchange|Interactive|Immersive|Full|MPEG-4)\\b"
        },
        {
          "name": "variable.parameter",
          "match": "\\b(CADGeometry|Core|CubeMapTexturing|DIS|EnvironmentalEffects|EnvironmentalSensor|EventUtilities|Followers|Geometry2D|Geometry3D|Geospatial|Grouping|HAnim|Interpolation|KeyDeviceSensor|Layering|Layout|Lighting|NURBS|Navigation|Networking|ParticleSystems|Picking|PointingDeviceSensor|Rendering|RigidBodyPhysics|Scripting|Shaders|Shape|Sound|Text|TextureProjection|Texturing|Texturing3D|Time|VolumeRendering|WebXR|X_ITE)\\b"
        },
        {
          "name": "constant.numeric",
          "match": "\\b(?:0[xX][\\da-fA-F]+|[+-]?(?:(?:(?:\\d*\\.\\d+)|(?:\\d+(?:\\.)?))(?:[eE][+-]?\\d+)?))\\b"
        },
        {
          "name": "variable.parameter",
          "match": "(\\w+)"
        },
        {
          "name": "strong",
          "match": "[:\\.]"
        }
      ]
    },
    "blockComment": {
      "name": "comment.block.X3D",
      "begin": "#\\/\\*",
      "end": "\\*\\/#",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.comment.begin.X3D"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.comment.end.X3D"
        }
      }
    },
    "strings": {
      "name": "string.quoted.double.X3D",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.X3D",
          "match": "\\\\."
        }
      ]
    }
  },
  "scopeName": "source.x3d"
}
